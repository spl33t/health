# Порт сервера мониторинга
PORT=4044

# Telegram-уведомления: true — включено, false/не задано — отключено (по умолчанию)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here  # получить у @BotFather
TELEGRAM_CHAT_ID=your_telegram_chat_id_here     # узнать через @userinfobot

# Email-уведомления: true — включено, false/не задано — отключено (по умолчанию)
EMAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=alerts@example.com
EMAIL_TO=admin@example.com

# Повтор алертов пока чекер в DOWN: интервал в часах (0 или не задано — только один DOWN до UP)
ALERT_DOWN_REMINDER_HOURS=0

# Проверка баланса VK Cloud: true — включено, false/не задано — отключено (по умолчанию)
VK_CLOUD_BALANCE_ENABLED=false
VK_CLOUD_EMAIL=your_vk_cloud_email@example.com
VK_CLOUD_PASS=your_vk_cloud_password_here

# Цели для HTTP-проверок (JSON): name — название, url — адрес, intervalMs — интервал проверки в мс. Пустой [] — HTTP-чекеры отключены
HTTP_CHECK_TARGETS='[]'

# Docker: каждый контейнер — отдельный чекер (список при старте). Имена — точное совпадение (compose service или имя из docker ps), * = все
DOCKER_CHECK_ENABLED=false
DOCKER_TARGETS='["*"]'
DOCKER_CONFIRM_THRESHOLD=3
# DOCKER_SOCKET_PATH=/var/run/docker.sock  # не задано — сокет по умолчанию
